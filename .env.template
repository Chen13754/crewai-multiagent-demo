# Copy this file to .env and fill in your DeepSeek API key before running the demo.
# The script maps MODEL_VARIANT to the official DeepSeek model name, then adds
# CrewAI's "deepseek/" provider prefix internally.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
MODEL_VARIANT=flash

# Keep CrewAI runtime data inside this project.
CREWAI_STORAGE_DIR=.cache/crewai
CREWAI_DISABLE_TELEMETRY=true
CREWAI_TRACING_ENABLED=false
CREWAI_TESTING=true
OTEL_SDK_DISABLED=true
